{
  "name": "@yuktishaalaa/yuktai",
  "version": "1.0.5",
  "description": "Privacy-first, offline-first Indic language AI and Web Orchestrator",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts --external react --external react-dom",
    "build": "tsup src/index.ts --format cjs,esm --clean --dts --minify --external react --external react-dom",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandeepmiriyala03/yuktai.git"
  },
  "keywords": [
    "indic",
    "ocr",
    "wcag",
    "vibe-coding",
    "offline-ai",
    "yuktai"
  ],
  "author": "Sandeep Miriyala",
  "license": "ISC",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "idb-keyval": "^6.2.2",
    "tesseract.js": "^7.0.0",
    "wasm-feature-detect": "^1.8.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  }
}
