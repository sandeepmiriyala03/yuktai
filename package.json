{
  "name": "yuktai-js",
  "version": "2.0.0",
  "description": "YuktAI — AI Engine. Do more with less.",
  "type": "module",

  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },

  "files": [
    "dist"
  ],

  "sideEffects": false,

  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "clean": "rimraf dist"
  },

  "keywords": [
    "ai",
    "ocr",
    "tesseract",
    "runtime",
    "browser-ai",
    "yuktai"
  ],

  "author": "Sandeep Miriyala",
  "license": "MIT",

  "peerDependencies": {
    "tesseract.js": "^6.0.0 || ^7.0.0"
  },

  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "@types/node": "^20.11.30"
  }
}