{
  "name": "@yuktishaalaa/yuktai",
  "version": "2.0.13",
  "description": "Privacy-first, offline-first universal accessibility engine with WCAG auto-fix, OCR, voice, and Indic language AI support.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "browser": "./dist/index.global.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm":  ">=8.0.0"
  },
  "files": ["dist", ".npmrc"],
  "scripts": {
    "dev":            "tsup --watch",
    "build":          "tsup",
    "prepublishOnly": "npm run build"
  },
  "author": "Sandeep Miriyala",
  "license": "ISC",
  "peerDependencies": {
    "react":     ">=17",
    "react-dom": ">=17",
    "next":      ">=13"
  },
  "peerDependenciesMeta": {
    "react":     { "optional": true },
    "react-dom": { "optional": true },
    "next":      { "optional": true }
  },
  "dependencies": {
    "idb-keyval":          "^6.2.2",
    "tesseract.js":        "^7.0.0",
    "wasm-feature-detect": "^1.8.0"
  },
  "devDependencies": {
    "@types/react":     "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react":            "^19.0.0",
    "react-dom":        "^19.0.0",
    "tsup":             "^8.5.1",
    "typescript":       "^5.0.0"
  }
}