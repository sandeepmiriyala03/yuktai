{
  "name": "@yuktishaalaa/yuktai",
  "version": "4.0.0",
  "description": "Universal runtime accessibility plugin — auto-fixes WCAG 2.2 violations with on-device AI features. Desktop only. Zero API keys. Zero cost.",
  "author": "Sandeep Miriyala — Yuktishaalaa AI Lab",
  "license": "ISC",
  "homepage": "https://aksharatantra.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/sandeepmiriyala03/yuktai"
  },

  "keywords": [
    "accessibility",
    "wcag",
    "a11y",
    "aria",
    "open-source",
    "next.js",
    "react",
    "browser-ai",
    "gemini-nano",
    "on-device-ai"
  ],

  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },

  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],

  "scripts": {
    "dev":            "tsup --watch",
    "build":          "tsup",
    "lint":           "eslint src --ext .ts,.tsx",
    "test":           "vitest run",
    "prepublishOnly": "npm run build"
  },

  "dependencies": {
    "react": ">=17.0.0"
  },

  "peerDependencies": {
    "react":     ">=17.0.0",
    "react-dom": ">=17.0.0"
  },

  "devDependencies": {
    "typescript":          "^5.4.5",
    "tsup":                "^8.0.2",
    "vitest":              "^1.6.0",
    "eslint":              "^8.57.0",

    "@types/react":        "^18.3.3",
    "@types/react-dom":    "^18.3.0",

    "react":               "^18.3.1",
    "react-dom":           "^18.3.1",

    "@mui/material":       "^6.0.0",
    "@mui/icons-material": "^6.0.0",
    "@emotion/react":      "^11.13.3",
    "@emotion/styled":     "^11.13.0"
  },

  "tsup": {
    "entry":    ["src/index.ts"],
    "format":   ["cjs", "esm"],
    "dts":      true,
    "clean":    true,
    "external": ["react", "react-dom"]
  },

  "engines": {
    "node": ">=18",
    "npm":  ">=8"
  },

  "browserslist": [
    "Chrome >= 127",
    "Edge >= 127"
  ]
}