{
  "name": "@yuktishaalaa/yuktai",
  "version": "3.0.14",
  "description": "Universal runtime accessibility plugin — auto-fixes WCAG 2.2 violations with on-device AI features. Zero API keys.",
  "author": "Sandeep Miriyala — Yuktishaalaa AI Lab",
  "license": "ISC",
  "homepage": "https://aksharatantra.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandeepmiriyala03/yuktai.git"
  },
  "keywords": [
    "accessibility",
    "wcag",
    "a11y",
    "aria",
    "react",
    "nextjs",
    "browser-ai",
    "on-device-ai",
    "transformers",
    "rag",
    "gemini-nano"
  ],

  "main":   "./dist/index.js",
  "module": "./dist/index.mjs",
  "types":  "./dist/index.d.ts",

  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },

  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],

  "scripts": {
    "dev":            "tsup --watch",
    "build":          "tsup",
    "lint":           "eslint src --ext .ts,.tsx",
    "test":           "vitest run",
    "prepublishOnly": "npm run build"
  },

  "dependencies": {},

  "peerDependencies": {
    "react":     ">=17.0.0",
    "react-dom": ">=17.0.0"
  },

  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    }
  },

  "devDependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@types/react":              "^18.3.3",
    "@types/react-dom":          "^18.3.0",
    "eslint":                    "^8.57.0",
    "tsup":                      "^8.0.2",
    "typescript":                "^5.4.5",
    "vitest":                    "^1.6.0"
  },

  "engines": {
    "node": ">=18",
    "npm":  ">=8"
  },

  "browserslist": [
    "Chrome >= 113",
    "Edge >= 113"
  ]
}